# .env - Environment Variables for AI Interview Chatbot

# OpenAI API Key (if using OpenAI LLM)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face Hub Token (if using Hugging Face models)
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to your data directory (optional, for flexibility)
DATA_DIR=data/

# Streamlit secret key (if using Streamlit login/session features)
STREAMLIT_SECRET_KEY=your_streamlit_secret

# Email server credentials (if sending email notifications, optional)
EMAIL_HOST=smtp.yourmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASSWORD=your_email_password

# Any other custom environment variables...
